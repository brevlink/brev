---
import '../styles/global.css';

const features = [
  {
    title: 'Own the domain',
    description: 'Use your custom domains for memorable, brand-safe short links.',
  },
  {
    title: 'Ship anywhere',
    description: 'Self-host the backend and dashboard with Docker, then point the CLI at your server.',
  },
  {
    title: 'Work from CLI',
    description: 'Create, list, inspect, and delete links without leaving the terminal.',
  },
  {
    title: 'Track the signal',
    description: 'Redirects include click tracking so every shared link stays measurable.',
  },
];

const steps = [
  {
    code: '01',
    title: 'Self-host',
    description: 'Run PostgreSQL, the FastAPI backend, Caddy, and the React dashboard on your infrastructure.',
  },
  {
    code: '02',
    title: 'Connect clients',
    description: 'Point the CLI at your Brev server. Browser and mobile clients can follow the same model later.',
  },
  {
    code: '03',
    title: 'Share',
    description: 'Use the CLI, API, or dashboard to publish short links and monitor clicks.',
  },
];

const shell = 'mx-auto w-[min(1120px,calc(100%_-_40px))] max-[620px]:w-[min(calc(100%_-_28px),1120px)]';
const serif = "font-['Instrument_Serif',Georgia,serif]";
const mono = "font-['JetBrains_Mono',ui-monospace,SFMono-Regular,monospace]";
const buttonBase =
  'inline-flex min-h-[46px] items-center justify-center rounded-full border border-[#071936] px-[22px] font-bold transition-[transform,box-shadow,background-color] duration-200 hover:-translate-y-0.5';
const buttonPrimary = `${buttonBase} bg-[#071936] text-[#f8f1e6] shadow-[0_18px_36px_rgba(7,25,54,0.2)]`;
const buttonSecondary = `${buttonBase} bg-[rgba(255,250,241,0.4)] text-[#071936]`;
const eyebrow =
  'mb-[22px] inline-flex items-center gap-2.5 text-[0.82rem] font-extrabold uppercase tracking-[0.18em] text-[#38516f] before:h-px before:w-[42px] before:bg-[#071936] before:content-[""]';
const sectionKicker = 'text-[0.78rem] font-extrabold uppercase tracking-[0.18em] text-[#38516f]';
const sectionHead =
  'mb-[30px] grid grid-cols-[0.8fr_1.2fr] items-end gap-11 max-[900px]:grid-cols-1';
const h2 = `${serif} mt-2.5 mb-0 text-[clamp(2.4rem,5vw,5rem)] leading-[0.9] tracking-[-0.01em]`;
const buttonLight = `${buttonBase} border-[#f8f1e6] bg-[#f8f1e6] text-[#071936]`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Brev is an open-source URL shortener built for self-hosted backend, dashboard, and CLI workflows."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://brevl.ink" />
    <meta property="og:title" content="Brev — Open-source link infrastructure" />
    <meta property="og:description" content="Self-host the backend and dashboard, then connect the CLI to your server." />
    <link rel="icon" type="image/webp" sizes="64x64" href="/brev_icona.webp" />
    <link rel="apple-touch-icon" href="/brev_icona.webp" />
    <title>Brev — Open-source link infrastructure</title>
  </head>
  <body class="min-h-screen scroll-smooth bg-[radial-gradient(circle_at_top_left,rgba(217,197,165,0.72),transparent_34rem),linear-gradient(135deg,#f8f1e6_0%,#efe6d4_54%,#e3d2b7_100%)] font-['Inter',ui-sans-serif,system-ui,sans-serif] text-[#071936] antialiased">
    <nav class="sticky top-0 z-20 border-b border-[rgba(7,25,54,0.14)] bg-[rgba(248,241,230,0.78)] backdrop-blur-[18px]">
      <div class={`${shell} flex h-[72px] items-center justify-between gap-6`}>
        <a href="/" class="flex items-center gap-3 font-extrabold tracking-[0.02em]" aria-label="Brev home">
          <img class="size-[34px]" src="/brev_icona.webp" alt="Brev" />
          <span>Brev</span>
        </a>

        <div class="flex items-center gap-7 text-[0.9rem] text-[#38516f] max-[900px]:hidden [&_a:hover]:text-[#071936]" aria-label="Primary navigation">
          <a href="#features">Features</a>
          <a href="#workflow">Workflow</a>
          <a href="#pricing">Pricing</a>
          <a href="https://github.com/brevlink/brev" target="_blank" rel="noreferrer">GitHub</a>
        </div>

        <div class="flex items-center max-[620px]:hidden">
          <a class={buttonPrimary} href="/app/login">Get started</a>
        </div>
      </div>
    </nav>

    <main>
      <header
        class={`${shell} relative grid grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] items-center gap-14 py-[92px] pb-20 before:pointer-events-none before:absolute before:right-[18%] before:top-16 before:size-[180px] before:rounded-full before:border before:border-[rgba(7,25,54,0.12)] before:content-[""] after:pointer-events-none after:absolute after:right-[2%] after:bottom-28 after:size-[76px] after:rotate-45 after:border after:border-[rgba(7,25,54,0.12)] after:content-[""] max-[900px]:grid-cols-1 max-[900px]:pt-[58px] max-[620px]:before:hidden max-[620px]:after:hidden`}
      >
        <div>
          <div class={eyebrow}>Open-source URL shortener</div>
          <h1 class={`${serif} m-0 text-[clamp(4.4rem,10.6vw,9.75rem)] leading-[0.77] tracking-[-0.02em] text-balance max-[620px]:text-[clamp(3.7rem,20vw,6.2rem)]`}>
            Short links,<br />long control.
          </h1>
          <p class="mt-[30px] max-w-[560px] text-[clamp(1.05rem,2vw,1.3rem)] leading-[1.7] text-[#38516f]">
            Brev gives you a self-hosted backend and dashboard for links, custom domains, click tracking,
            and a CLI that connects to your own server.
          </p>

          <div class="mt-[34px] flex flex-wrap gap-3.5">
            <a class={buttonPrimary} href="/app/login">Open dashboard</a>
            <a class={buttonSecondary} href="https://github.com/brevlink/brev" target="_blank" rel="noreferrer">
              View source
            </a>
          </div>

          <div class="mt-11 flex flex-wrap gap-[18px] text-[0.9rem] text-[#38516f] [&_span]:border-l [&_span]:border-[rgba(7,25,54,0.14)] [&_span]:pl-4" aria-label="Brev highlights">
            <span>MIT licensed</span>
            <span>Self-hosted first</span>
            <span>CLI connects to your server</span>
          </div>
        </div>

        <aside class="relative z-[1] overflow-hidden rounded-[34px] border border-[rgba(7,25,54,0.14)] bg-[rgba(255,250,241,0.54)] p-7 shadow-[0_28px_90px_rgba(7,25,54,0.16)]" aria-label="Brev product preview">
          <div class="mb-[42px] flex items-center justify-between">
            <span class={`${mono} rounded-full border border-[rgba(7,25,54,0.14)] px-3 py-2 text-[0.78rem] text-[#38516f]`}>brevl.ink/go</span>
            <span class="rounded-full border border-[rgba(7,25,54,0.14)] px-3 py-2 text-[0.78rem] text-[#38516f]">42 clicks</span>
          </div>

          <div class="grid grid-cols-[42px_1fr] items-start gap-4 border-t border-[rgba(7,25,54,0.14)] py-5">
            <span class="font-extrabold text-[#d9c5a5]">01</span>
            <div>
              <strong class="mb-2 block text-[1.05rem]">Your domain</strong>
              <p class="m-0 leading-[1.55] text-[#38516f]">Point a custom domain at Brev and keep every shared URL on-brand.</p>
            </div>
          </div>

          <div class="grid grid-cols-[42px_1fr] items-start gap-4 border-y border-[rgba(7,25,54,0.14)] py-5">
            <span class="font-extrabold text-[#d9c5a5]">02</span>
            <div>
              <strong class="mb-2 block text-[1.05rem]">Your stack</strong>
              <p class="m-0 leading-[1.55] text-[#38516f]">PostgreSQL auth, FastAPI, Caddy routing, and no vendor lock-in.</p>
            </div>
          </div>

          <div class={`${mono} mt-[26px] rounded-[20px] bg-[#071936] p-[18px] text-[0.84rem] leading-[1.85] text-[#f8f1e6] [&_span]:text-[#d9c5a5]`}>
            <span>$</span> brev create https://example.com --slug go<br />
            <span>→</span> https://brevl.ink/go
          </div>
        </aside>
      </header>

      <section id="features" class={`${shell} py-[74px]`}>
        <div class={sectionHead}>
          <div>
            <span class={sectionKicker}>Features</span>
            <h2 class={h2}>Minimal by design.</h2>
          </div>
          <p class="m-0 text-[1.06rem] leading-[1.75] text-[#38516f]">
            Everything is focused on one product promise: own the link layer, run the web stack yourself,
            and connect lightweight clients to it.
          </p>
        </div>

        <div class="grid grid-cols-4 overflow-hidden rounded-[30px] border border-[rgba(7,25,54,0.14)] bg-[rgba(255,250,241,0.3)] max-[900px]:grid-cols-2 max-[620px]:grid-cols-1">
          {
            features.map((feature, index) => (
              <article
                class={`flex min-h-[252px] flex-col justify-between border-[rgba(7,25,54,0.14)] p-7 ${
                  index < features.length - 1 ? 'border-r max-[620px]:border-r-0 max-[620px]:border-b' : ''
                } ${index === 1 ? 'max-[900px]:border-r-0 max-[900px]:border-b' : ''} ${
                  index === 0 ? 'max-[900px]:border-b' : ''
                } ${index === 2 ? 'max-[900px]:border-r' : ''}`}
              >
                <div class="grid size-[38px] place-items-center rounded-full border border-[#071936]">/</div>
                <div>
                  <h3 class="m-0 text-xl tracking-[-0.03em]">{feature.title}</h3>
                  <p class="mt-[22px] mb-0 leading-[1.65] text-[#38516f]">{feature.description}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section id="workflow" class={`${shell} py-[74px]`}>
        <div class={sectionHead}>
          <div>
            <span class={sectionKicker}>Workflow</span>
            <h2 class={h2}>Three clear moves.</h2>
          </div>
          <p class="m-0 text-[1.06rem] leading-[1.75] text-[#38516f]">
            From local deploys to CLI workflows, Brev keeps the path from long URL to trackable short link
            intentionally simple.
          </p>
        </div>

        <div class="grid gap-4">
          {
            steps.map((step) => (
              <article class="grid grid-cols-[120px_1fr_1.1fr] items-center gap-7 rounded-[26px] border border-[rgba(7,25,54,0.14)] bg-[rgba(255,250,241,0.36)] p-7 max-[900px]:grid-cols-1 max-[900px]:gap-3">
                <span class={`${mono} text-[2.2rem] font-extrabold text-[#d9c5a5]`}>{step.code}</span>
                <h3 class="m-0 text-[1.55rem] tracking-[-0.04em]">{step.title}</h3>
                <p class="m-0 leading-[1.65] text-[#38516f]">{step.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="pricing" class={`${shell} py-[74px]`}>
        <div class={sectionHead}>
          <div>
            <span class={sectionKicker}>Pricing</span>
            <h2 class={h2}>Open source first.</h2>
          </div>
          <p class="m-0 text-[1.06rem] leading-[1.75] text-[#38516f]">
            Use the MIT-licensed stack forever. Brev Cloud can come later for people who want managed
            infrastructure instead of operating their own server.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-[18px] max-[900px]:grid-cols-1">
          <article class="rounded-[30px] border border-[rgba(7,25,54,0.14)] bg-[rgba(255,250,241,0.42)] p-[34px]">
            <h3 class="mt-0 mb-[22px] text-xl">Self-hosted</h3>
            <div class="text-[clamp(3rem,6vw,5.8rem)] font-extrabold leading-[0.85] tracking-[-0.07em]">$0</div>
            <p class="mt-4 mb-7 text-[#38516f]">Forever. Docker compose, PostgreSQL, FastAPI, dashboard, and CLI.</p>
            <ul class="m-0 list-none p-0">
              <li class="border-t border-[rgba(127,105,73,0.18)] py-2.5 text-[#38516f]">Unlimited links on your own infrastructure</li>
              <li class="border-t border-[rgba(127,105,73,0.18)] py-2.5 text-[#38516f]">Custom domains behind your reverse proxy</li>
              <li class="border-t border-[rgba(127,105,73,0.18)] py-2.5 text-[#38516f]">OpenAPI docs and CLI access</li>
            </ul>
          </article>

          <article class="rounded-[30px] border border-[rgba(7,25,54,0.14)] bg-[#071936] p-[34px] text-[#f8f1e6]">
            <h3 class="mt-0 mb-[22px] text-xl">Brev Cloud · coming soon</h3>
            <div class="text-[clamp(3rem,6vw,5.8rem)] font-extrabold leading-[0.85] tracking-[-0.07em]">$5</div>
            <p class="mt-4 mb-7 text-[rgba(248,241,230,0.72)]">One-time per domain. Managed DNS, SSL, deploys, backups, and scaling.</p>
            <ul class="m-0 list-none p-0">
              <li class="border-t border-[rgba(248,241,230,0.16)] py-2.5 text-[rgba(248,241,230,0.72)]">No infrastructure to maintain</li>
              <li class="border-t border-[rgba(248,241,230,0.16)] py-2.5 text-[rgba(248,241,230,0.72)]">Bring your domain to brevl.ink</li>
              <li class="border-t border-[rgba(248,241,230,0.16)] py-2.5 text-[rgba(248,241,230,0.72)]">Hosted updates and operational support</li>
            </ul>
          </article>
        </div>
      </section>

      <section class={`${shell} py-[74px] pb-[104px] text-center`}>
        <div class="relative overflow-hidden rounded-[36px] bg-[#071936] px-7 py-[58px] text-[#f8f1e6] before:pointer-events-none before:absolute before:inset-[18px] before:rounded-[28px] before:border before:border-[rgba(248,241,230,0.18)] before:content-['']">
          <h2 class={`${h2} relative mb-[22px]`}>Make every link feel intentional.</h2>
          <p class="relative mx-auto mt-0 mb-[30px] max-w-[560px] leading-[1.7] text-[rgba(248,241,230,0.72)]">
            Install the CLI, self-host the stack, or join Brev Cloud when it opens. Your domain, your links, your way.
          </p>
          <a class={`${buttonLight} relative`} href="/app/login">Get started</a>
        </div>
      </section>
    </main>

    <footer class="border-t border-[rgba(7,25,54,0.14)] py-[34px] text-[#38516f]">
      <div class={`${shell} flex items-center justify-between gap-6 text-[0.92rem] max-[620px]:flex-col max-[620px]:items-start`}>
        <span>© 2026 Brev. MIT licensed.</span>
        <div class="flex flex-wrap justify-end gap-x-[22px] gap-y-2">
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/cookies">Cookies</a>
          <a href="/legal">Legal notice</a>
          <a href="/subprocessors">Subprocessors</a>
          <a href="https://github.com/brevlink/brev/security/advisories/new" target="_blank" rel="noreferrer">Security / report</a>
          <a href="https://github.com/brevlink/brev" target="_blank" rel="noreferrer">GitHub</a>
          <a href="https://matteogenovese.com" target="_blank" rel="noreferrer">Author</a>
        </div>
      </div>
    </footer>
  </body>
</html>
