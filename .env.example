# Brev
# Copia questo file in .env e modifica i valori prima di avviare:
#   cp .env.example .env
#   openssl rand -hex 32   # JWT_SECRET
#   openssl rand -hex 24   # DB_PASSWORD

# Segreti obbligatori (placeholder, non usare questi valori)
JWT_SECRET=change-me-in-production
DB_PASSWORD=change-me

# Docker Compose
HTTP_PORT=80
BREV_DATA=./data
BREV_NETWORK_NAME=brev_net
BREV_NETWORK_EXTERNAL=false
POSTGRES_IMAGE=postgres:16-alpine
BACKEND_IMAGE=brev-backend:local
LANDING_IMAGE=brev-landing:local
DASHBOARD_IMAGE=brev-dashboard:local
CADDY_IMAGE=brev-caddy:local

# Database
DB_USER=postgres
DB_NAME=brev

# Applicazione
DEFAULT_DOMAIN=brevl.ink
ENVIRONMENT=development
SECURE_COOKIES=false
DOCS_ENABLED=true
CLOUD_MODE=false
REQUIRE_VERIFIED_EMAIL=false
FREE_CUSTOM_DOMAINS=0
BREV_DEBUG=false
CORS_ORIGINS=["https://brevl.ink","https://app.brevl.ink"]
CNAME_TARGET=proxy.brevl.ink.

# Auth email. `none` fails closed; configure SMTP or the generic API adapter.
APP_BASE_URL=http://localhost
# Real routes implemented by the deployed frontend. Tokens are appended as
# URL fragments (#token=...), so they are not sent to HTTP access logs.
FRONTEND_VERIFICATION_URL=
FRONTEND_PASSWORD_RESET_URL=
EMAIL_PROVIDER=none
EMAIL_FROM=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_STARTTLS=true
# EMAIL_API_URL=
# EMAIL_API_TOKEN=

# Stripe one-time (solo Brev Cloud; lascia vuoto per self-hosted)
# Usa solo valori di test durante la configurazione locale. Non inserire
# chiavi live in questo file o nel repository.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# STRIPE_SUCCESS_URL=https://brevl.ink/app/dashboard?billing=success
# STRIPE_CANCEL_URL=https://brevl.ink/app/dashboard?billing=cancelled
